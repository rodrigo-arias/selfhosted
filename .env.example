# User and Group ID for Docker containers
PUID=1000
PGID=10

# Time zone
TZ="Etc/UTC"

# Docker application data path
APPDATA_ROOT=""

# Media files path
MEDIA_ROOT=""

# Host LAN IP — used for direct port bindings and local DNS
LAN_IP=127.0.0.1

# Public domain for local DNS and proxy
DOMAIN=""

# VPN for Gluetun (Wireguard)
VPN_SERVICE_PROVIDER=""
VPN_WIREGUARD_PRIVATE_KEY=""
VPN_WIREGUARD_ADDRESS=""
VPN_COUNTRY=""

# qBittorrent for Gluetun
QBITTORRENT_USER=""
QBITTORRENT_PASS=""

# Cloudflare Tunnel token
CLOUDFLARE_TUNNEL_TOKEN=""

